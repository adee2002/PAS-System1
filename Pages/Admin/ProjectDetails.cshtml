@page "{id:int}"
@model WebApplication1.Pages.Admin.ProjectDetailsModel
@{
    ViewData["Title"] = "Project Details";
}

<h2 class="page-title">Project Details</h2>

<div class="card card-box">
    <div class="card-header card-header-custom">
        Full Project Information
    </div>

    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Title</div>
            <div class="col-md-9">@Model.ProjectItem?.Title</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Student</div>
            <div class="col-md-9">@Model.ProjectItem?.Student?.FullName</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Research Area</div>
            <div class="col-md-9">@Model.ProjectItem?.ResearchArea?.Name</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Status</div>
            <div class="col-md-9">@Model.ProjectItem?.Status</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Tech Stack</div>
            <div class="col-md-9">@Model.ProjectItem?.TechStack</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-bold">Abstract</div>
            <div class="col-md-9">@Model.ProjectItem?.Abstract</div>
        </div>

        <div class="mt-4">
            <a asp-page="/Admin/Projects" class="btn btn-secondary">Back</a>
            <a asp-page="/Admin/EditProject" asp-route-id="@Model.ProjectItem?.Id" class="btn btn-warning">
                Edit Project
            </a>
        </div>

    </div>
</div>