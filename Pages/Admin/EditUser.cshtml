@page "{id:int}"
@model WebApplication1.Pages.Admin.EditUserModel
@{
    ViewData["Title"] = "Edit User";
}

<h2 class="page-title">Edit User</h2>

<div class="card card-box">
    <div class="card-header card-header-custom">
        Update User Details
    </div>
    <div class="card-body">
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="UserItem.Id" />

            <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input asp-for="UserItem.FullName" class="form-control" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input asp-for="UserItem.Email" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Password Hash</label>
                <input asp-for="UserItem.PasswordHash" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Role</label>
                <select asp-for="UserItem.Role" class="form-select">
                    <option value="Admin">Admin</option>
                    <option value="Student">Student</option>
                    <option value="Supervisor">Supervisor</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select asp-for="UserItem.IsActive" class="form-select">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Update User</button>
                <a asp-page="/Admin/Users" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>