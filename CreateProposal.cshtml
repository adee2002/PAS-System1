@model ProjectApprovalSystem.Models.ViewModels.CreateProjectViewModel

@{
    ViewData["Title"] = "Create Project Proposal";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Submit New Project Proposal</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CreateProposal" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter your project title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                            <small class="form-text text-muted">Choose a clear and descriptive title for your project.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Abstract" class="form-label"></label>
                            <textarea asp-for="Abstract" class="form-control" rows="6" placeholder="Describe your project idea, objectives, and expected outcomes..."></textarea>
                            <span asp-validation-for="Abstract" class="text-danger"></span>
                            <small class="form-text text-muted">Provide a detailed description of your project (minimum 50 characters).</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TechnicalStack" class="form-label"></label>
                            <input asp-for="TechnicalStack" class="form-control" placeholder="e.g., ASP.NET Core, SQL Server, Bootstrap, jQuery" />
                            <span asp-validation-for="TechnicalStack" class="text-danger"></span>
                            <small class="form-text text-muted">List all technologies, frameworks, and tools you plan to use.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ResearchAreaId" class="form-label"></label>
                            <select asp-for="ResearchAreaId" asp-items="Model.ResearchAreas" class="form-select">
                                <option value="">-- Select Research Area --</option>
                            </select>
                            <span asp-validation-for="ResearchAreaId" class="text-danger"></span>
                            <small class="form-text text-muted">Choose the category that best fits your project.</small>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Dashboard" class="btn btn-secondary me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-primary">Submit Proposal</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body bg-light">
                    <h5 class="card-title">📝 Tips for a Good Proposal</h5>
                    <ul class="mb-0">
                        <li>Be specific about your project goals and objectives</li>
                        <li>Explain the technical challenges you expect to face</li>
                        <li>List all required technologies clearly</li>
                        <li>Describe the expected outcomes and deliverables</li>
                        <li>Mention any prior work or research in this area</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}