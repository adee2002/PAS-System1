@model ProjectApprovalSystem.Models.Match

@{
    ViewData["Title"] = "Match Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">🎉 Congratulations! You've Been Matched</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-success">
                        <h4 class="alert-heading">Match Confirmed!</h4>
                        <p>Your project has been matched with a supervisor. You can now see their contact information below.</p>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0">Supervisor Information</h5>
                                </div>
                                <div class="card-body">
                                    <dl class="row">
                                        <dt class="col-sm-3">Name:</dt>
                                        <dd class="col-sm-9">@Model.Supervisor?.FirstName @Model.Supervisor?.LastName</dd>

                                        <dt class="col-sm-3">Email:</dt>
                                        <dd class="col-sm-9">
                                            <a href="mailto:@Model.Supervisor?.Email">@Model.Supervisor?.Email</a>
                                        </dd>

                                        <dt class="col-sm-3">Match Date:</dt>
                                        <dd class="col-sm-9">@Model.ConfirmedDate?.ToString("MMMM dd, yyyy")</dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="card">
                                <div class="card-header bg-secondary text-white">
                                    <h5 class="mb-0">Your Project</h5>
                                </div>
                                <div class="card-body">
                                    <dl class="row">
                                        <dt class="col-sm-3">Title:</dt>
                                        <dd class="col-sm-9">@Model.Project?.Title</dd>

                                        <dt class="col-sm-3">Status:</dt>
                                        <dd class="col-sm-9">
                                            <span class="badge bg-success">Matched</span>
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a asp-action="Dashboard" class="btn btn-primary">Back to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>