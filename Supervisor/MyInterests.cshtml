@model List<SupervisorInterestViewModel>
@{
    ViewData["Title"] = "My Interests";
    var selectedProjectId = ViewData["SelectedProjectId"] as int?;
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
        <h2 class="mb-0">My Interested Projects</h2>
        <a class="btn btn-outline-primary" href="/Supervisor/Dashboard">Back to Dashboard</a>
    </div>

    @if (TempData["Success"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">You have not expressed interest in any projects yet.</div>
    }
    else
    {
        <div class="alert alert-success">The project you selected is now listed below as Interested.</div>
        <div class="row g-3">
            @foreach (var interest in Model)
            {
                var isSelected = selectedProjectId.HasValue && selectedProjectId.Value == interest.ProjectId;
                var badgeClass = isSelected ? "bg-success" : "bg-primary";
                var badgeText = isSelected ? "Interested" : (string.IsNullOrWhiteSpace(interest.Status) ? "Interested" : interest.Status);

                <div class="col-12 col-lg-6">
                    <div class="card h-100 shadow-sm border-0 @(isSelected ? "border-success border-2" : "")">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                <h5 class="card-title mb-0">@interest.Title</h5>
                                <span class="badge @badgeClass">@badgeText</span>
                            </div>

                            @if (isSelected)
                            {
                                <div class="alert alert-success py-2 px-3 mb-3">This is the project you just selected.</div>
                            }

                            <p class="text-muted mb-2"><strong>Research Area:</strong> @interest.ResearchArea</p>
                            <p class="text-muted mb-2"><strong>Tech Stack:</strong> @interest.TechStack</p>
                            <p class="text-muted mb-2"><strong>Tags:</strong> @interest.Tags</p>
                            <p class="card-text flex-grow-1">@interest.Abstract</p>

                            <small class="text-muted mt-3">Interested on: @interest.InterestedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
