@page
@model WebApplication1.Pages.Admin.ResearchAreasModel
@{
    ViewData["Title"] = "Research Areas";
}

<h2 class="page-title">Manage Research Areas</h2>

<!-- ADD FORM -->
<div class="card card-box mb-4">
    <div class="card-header card-header-custom">
        Add New Research Area
    </div>

    <div class="card-body">
        <form method="post" class="row g-3">

            <div class="col-md-9">
                <label class="form-label">Research Area Name</label>
                <input asp-for="NewArea.Name" class="form-control" placeholder="Enter research area" />
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100 btn-custom">
                    Add
                </button>
            </div>

        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card card-box">
    <div class="card-header card-header-custom">
        Research Area List
    </div>

    <div class="card-body">

        <table class="table table-bordered table-hover align-middle text-center">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Research Area</th>
                    <th style="width:200px;">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.AreaList.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="empty-state">
                            No research areas found
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var area in Model.AreaList)
                    {
                        <tr>
                            <td>@area.Id</td>

                            <td class="fw-semibold">
                                @area.Name
                            </td>

                            <td>
                                <div class="table-actions">

                                    <!-- EDIT BUTTON -->
                                    <a asp-page="EditResearchArea"
                                       asp-route-id="@area.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <!-- DELETE BUTTON -->
                                    <form method="post"
                                          asp-page-handler="Delete"
                                          style="display:inline;">

                                        <input type="hidden"
                                               name="id"
                                               value="@area.Id" />

                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this research area?');">
                                            Delete
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>

    </div>
</div>

<!-- BACK BUTTON -->
<div class="mt-3">
    <a asp-page="/Admin/Dashboard" class="btn btn-secondary">
        Back to Dashboard
    </a>
</div>