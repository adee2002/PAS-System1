@page "{id:int}"
@model WebApplication1.Pages.Admin.EditResearchAreaModel

<h2>Edit Research Area</h2>

<form method="post">
    <input type="hidden" asp-for="Area.Id" />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input asp-for="Area.Name" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-page="/Admin/ResearchAreas" class="btn btn-secondary">Cancel</a>
</form>