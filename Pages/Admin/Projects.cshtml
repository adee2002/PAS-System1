@page
@model WebApplication1.Pages.Admin.ProjectsModel
@{
    ViewData["Title"] = "Projects";
}

<h2 class="page-title">Project Management</h2>

<!-- ================= ADD PROJECT ================= -->
<div class="card card-box mb-4">
    <div class="card-header card-header-custom">
        Add New Project
    </div>

    <div class="card-body">
        <form method="post" class="row g-3">

            <div class="col-md-6">
                <label class="form-label">Project Title</label>
                <input asp-for="NewProject.Title" class="form-control" placeholder="Enter project title" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Tech Stack</label>
                <input asp-for="NewProject.TechStack" class="form-control" placeholder="Enter tech stack" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Student</label>
                <select asp-for="NewProject.StudentId" class="form-select">
                    <option value="">Select student</option>
                    @foreach (var student in Model.Students)
                    {
                        <option value="@student.Id">@student.FullName</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Research Area</label>
                <select asp-for="NewProject.ResearchAreaId" class="form-select">
                    <option value="">Select research area</option>
                    @foreach (var area in Model.ResearchAreas)
                    {
                        <option value="@area.Id">@area.Name</option>
                    }
                </select>
            </div>

            <div class="col-12">
                <label class="form-label">Abstract</label>
                <textarea asp-for="NewProject.Abstract" class="form-control" rows="3" placeholder="Enter project abstract"></textarea>
            </div>

            <div class="col-md-6">
                <label class="form-label">Status</label>
                <select asp-for="NewProject.Status" class="form-select">
                    <option value="Pending">Pending</option>
                    <option value="Under Review">Under Review</option>
                    <option value="Matched">Matched</option>
                </select>
            </div>

            <div class="col-md-6 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    Add Project
                </button>
            </div>

        </form>
    </div>
</div>

<!-- ================= SEARCH & FILTER ================= -->
<div class="card card-box mb-4">
    <div class="card-header card-header-custom">
        Search & Filter
    </div>

    <div class="card-body">
        <form method="get" class="row g-3">

            <div class="col-md-6">
                <input type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="form-control"
                       placeholder="Search by project title..." />
            </div>

            <div class="col-md-4">
                <select name="statusFilter" class="form-select">
                    <option value="">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Under Review">Under Review</option>
                    <option value="Matched">Matched</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </form>
    </div>
</div>

<!-- ================= PROJECT TABLE ================= -->
<div class="card card-box">
    <div class="card-header card-header-custom">
        All Projects
    </div>

    <div class="card-body">

        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Student</th>
                    <th>Research Area</th>
                    <th>Status</th>
                    <th style="width: 350px;">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.ProjectList.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="empty-state">No projects found</td>
                    </tr>
                }
                else
                {
                    @foreach (var project in Model.ProjectList)
                    {
                        <tr>
                            <td>@project.Title</td>
                            <td>@project.Student?.FullName</td>
                            <td>@project.ResearchArea?.Name</td>

                            <td>
                                @if (project.Status == "Matched")
                                {
                                    <span class="badge bg-success">Matched</span>
                                }
                                else if (project.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Under Review</span>
                                }
                            </td>

                            <td>
                                <div class="table-actions">

                                    <!-- DETAILS -->
                                    <a asp-page="ProjectDetails"
                                       asp-route-id="@project.Id"
                                       class="btn btn-info btn-sm text-dark">
                                        Details
                                    </a>

                                    <!-- EDIT -->
                                    <a asp-page="EditProject"
                                       asp-route-id="@project.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <!-- UPDATE STATUS -->
                                    <form method="post"
                                          asp-page-handler="UpdateStatus"
                                          class="d-flex gap-2">

                                        <input type="hidden" name="id" value="@project.Id" />

                                        <select name="status" class="form-select form-select-sm">
                                            <option value="Pending" selected="@(project.Status == "Pending")">Pending</option>
                                            <option value="Under Review" selected="@(project.Status == "Under Review")">Under Review</option>
                                            <option value="Matched" selected="@(project.Status == "Matched")">Matched</option>
                                        </select>

                                        <button type="submit" class="btn btn-primary btn-sm">
                                            Update
                                        </button>
                                    </form>

                                    <!-- DELETE -->
                                    <form method="post" asp-page-handler="Delete">
                                        <input type="hidden" name="id" value="@project.Id" />
                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Delete this project?');">
                                            Delete
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>

    </div>
</div>
<div class="mt-3">
    <a asp-page="/Admin/Dashboard" class="btn btn-secondary">
        Back to Dashboard
    </a>
</div>