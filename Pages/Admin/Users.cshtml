@page
@model WebApplication1.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
}

<h2 class="page-title">User Management</h2>

<!-- Add User Form -->
<div class="card card-box mb-4">
    <div class="card-header card-header-custom">
        Add New User
    </div>
    <div class="card-body">
        <form method="post" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input asp-for="NewUser.FullName" class="form-control" placeholder="Enter full name" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input asp-for="NewUser.Email" class="form-control" placeholder="Enter email" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Password Hash</label>
                <input asp-for="NewUser.PasswordHash" class="form-control" placeholder="Enter password / hash" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Role</label>
                <select asp-for="NewUser.Role" class="form-select">
                    <option value="">Select role</option>
                    <option value="Admin">Admin</option>
                    <option value="Student">Student</option>
                    <option value="Supervisor">Supervisor</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select asp-for="NewUser.IsActive" class="form-select">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Add User</button>
            </div>
        </form>
    </div>
</div>

<!-- User Table -->
<div class="card card-box">
    <div class="card-header card-header-custom">
        User List
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.UserList.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="empty-state">No users found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model.UserList)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-dark">Admin</span>
                                }
                                else if (user.Role == "Student")
                                {
                                    <span class="badge bg-primary">Student</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Supervisor</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="table-actions">
                                    <a asp-page="EditUser" asp-route-id="@user.Id" class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form method="post" asp-page-handler="Delete" style="display:inline;">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this user?');">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
<div class="mt-3">
    <a asp-page="/Admin/Dashboard" class="btn btn-secondary">
        Back to Dashboard
    </a>
</div>